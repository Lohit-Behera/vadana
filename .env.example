# Copy to .env and fill in (never commit .env).
# Used by scripts/build-release.ps1 before pnpm tauri build.

# Full contents of your Tauri updater private key file (single line)
TAURI_SIGNING_PRIVATE_KEY=

# Passphrase if the key was generated with a password; leave empty if none
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
