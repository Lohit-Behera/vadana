{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vadana",
  "version": "0.2.5",
  "identifier": "com.lohit.vadana",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vadana",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:* https://127.0.0.1:*; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "dmg", "app"],
    "resources": {
      "resources/backend/": "resources/backend/",
      "windows/cleanup-appdata.ps1": "resources/cleanup-appdata.ps1"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis/header.bmp",
        "sidebarImage": "icons/nsis/sidebar.bmp",
        "installerHooks": "windows/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://lohit-behera.github.io/vadana/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDMjk1MkFGQUM5Qzk0Q0MKUldUTWxKeXNyMUlwM0J5ZVNmTmt3dksrNmhqdGpmc3JLZStCSDBXeWtNcU4xaGVYWmxHSU9sVU8K"
    }
  }
}
